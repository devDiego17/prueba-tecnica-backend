// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Merchant {
  id         String         @id @default(uuid()) @db.Uuid
  name       String
  email      String         @unique
  api_key    String         @unique
  status     MerchantStatus @default(active)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  transactions Transaction[]
  settlements  Settlement[]

  @@map("merchants")
}

model Transaction {
  id          String            @id @default(uuid()) @db.Uuid
  merchantId  String            @db.Uuid @map("merchant_id")
  amount      Decimal           @db.Decimal(12, 2)
  currency    Currency
  type        TransactionType
  status      TransactionStatus @default(pending)
  reference   String            @unique
  metadata    Json?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  merchant               Merchant               @relation(fields: [merchantId], references: [id])
  settlementTransactions SettlementTransaction[]

  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
  @@index([merchantId, status])
  @@map("transactions")
}

model Settlement {
  id               String         @id @default(uuid()) @db.Uuid
  merchantId       String         @db.Uuid @map("merchant_id")
  totalAmount      Decimal        @db.Decimal(14, 2) @map("total_amount")
  transactionCount Int            @map("transaction_count")
  status           SettlementStatus @default(pending)
  periodStart      DateTime       @map("period_start")
  periodEnd        DateTime       @map("period_end")
  createdAt        DateTime       @default(now()) @map("created_at")

  merchant               Merchant               @relation(fields: [merchantId], references: [id])
  settlementTransactions SettlementTransaction[]

  @@index([merchantId])
  @@map("settlements")
}

model SettlementTransaction {
  settlementId  String @db.Uuid @map("settlement_id")
  transactionId String @unique @db.Uuid @map("transaction_id")

  settlement  Settlement  @relation(fields: [settlementId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id])

  @@id([settlementId, transactionId])
  @@map("settlement_transactions")
}

enum MerchantStatus {
  active
  inactive
}

enum Currency {
  GTQ
  COP
  USD
}

enum TransactionType {
  payin
  payout
}

enum TransactionStatus {
  pending
  approved
  completed
  failed
  rejected
}

enum SettlementStatus {
  pending
  processed
  paid
}


